# Update these with your Supabase details from your project settings > API
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
ANTHROPIC_API_KEY=your-anthropic-api-key
GOOGLE_PLACES_API_KEY=your-google-places-api-key
MAINTENANCE_REVIEW_WORKER_SECRET=your-maintenance-review-worker-secret
MAINTENANCE_REVIEW_BATCH_SIZE=10
MAINTENANCE_REVIEW_MAX_RETRIES=3

# Production site URL — overrides window.location.origin for email confirmation links.
# Set this to your Vercel deployment URL in production.
NEXT_PUBLIC_SITE_URL=https://rent-platform-orpin.vercel.app

SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
ANTHROPIC_API_KEY=your-anthropic-api-key
CRON_SECRET=your-cron-secret
MOCK_FAILURE_RATE=0.1

# Twilio webhook signature validation
# Set to true in development to skip Twilio signature checks
TWILIO_SKIP_VALIDATION=true
# Optional: explicit URL for Twilio signature validation (overrides request URL)
# TWILIO_WEBHOOK_URL=https://your-app.vercel.app/api/sms

# Internal API endpoint protection
# Required secret for X-Internal-Secret header on internal API routes
INTERNAL_API_SECRET=your-internal-api-secret

# Stripe mode — controls which key set is active: 'demo' (test) or 'monetize' (live)
STRIPE_MODE=demo

# Stripe test keys (used when STRIPE_MODE=demo)
# https://dashboard.stripe.com/test/apikeys
STRIPE_TEST_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_TEST_PUBLISHABLE_KEY=pk_test_...
STRIPE_TEST_WEBHOOK_SECRET=whsec_...

# Stripe live keys (used when STRIPE_MODE=monetize)
# https://dashboard.stripe.com/apikeys
STRIPE_LIVE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_LIVE_PUBLISHABLE_KEY=pk_live_...
STRIPE_LIVE_WEBHOOK_SECRET=whsec_...
