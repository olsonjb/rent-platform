# Update these with your Supabase details from your project settings > API
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# Production site URL — overrides window.location.origin for email confirmation links.
# Set this to your Vercel deployment URL in production.
NEXT_PUBLIC_SITE_URL=https://rent-platform-orpin.vercel.app

# Stripe — get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Supabase service role key — from project settings > API (keep secret, server-only)
SUPABASE_SERVICE_ROLE_KEY=eyJ...
